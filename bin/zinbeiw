      rescue StandardError => es
        p es
        puts 'エラーです。文字列を確認してください！'
      end

      begin
        Dir.chdir(mk)
      rescue Errno::EEXIST
        Errno::EEXIST
      end

      begin
        print 'フォルダ名を入力してください：　'

        ma = readline.chomp!
