        puts 'エラーです。数字を確認してください！'
      end

      puts ''

      t = Time.local(nen, mon, days)

      print '日曜日ですか？：'
      puts  t.sunday?
      print '月曜日ですか？：'
      puts t.monday?
      print '火曜日ですか？：'
      puts  t.tuesday?
      print '水曜日ですか？：'
