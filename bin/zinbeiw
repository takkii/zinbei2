      print '>'

    elsif line.match?(once[8])
      puts ''
      puts '日付の曜日をtrue,falseで判定します'
      puts '半角数字で入力してください'
      puts 'それでは、スタート！'
      puts ''

      begin
        puts '調べたい年を入力してください'
        print '>'
        nen = gets.chomp.to_i
