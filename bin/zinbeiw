        print '削除したいフォルダ名を拡張子を含んで入力してください：　'

        rem = readline.chomp!
        Dir.rmdir(rem)

        puts '削除しました。'
      rescue StandardError => ex
        p ex
        puts 'エラーです。ファイル名を確認してください。\ｎ'
        retry
      ensure
        puts '終了は exit を入力してください！'
