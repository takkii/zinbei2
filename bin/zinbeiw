      puts ''
      puts 'FizzBizz問題の出力結果です!'
      puts ''
      (1..nu).each do |t|
        if t % 15 == 0
          print 'FizzBizz'
        elsif t % 3 == 0
          print 'Fizz'
        elsif t % 5 == 0
          print 'Bizz'
