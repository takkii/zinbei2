#!/usr/bin/env ruby
# frozen_string_literal: true

# vim: filetype=ruby

class Writer
  def word
    one = ARGV[0]
    two = ARGV[1]

    File.open(one, 'a:sjis', perm = 0o666) do |out_f|
      out_f.write(two)
      print ' 書き込み処理をしました、終了します... '
      out_f.close
    end
  end
end

me = ARGV[0]

if me.nil?
  print 'iruka is zinbei in Copyright Takayuki Kamiyama,I made in 2016.'
elsif me
  Writer.new.word
else
  print 'Not other arguments!'
end

__END__
