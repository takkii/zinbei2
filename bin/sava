#!/usr/bin/env ruby
# -*- coding: utf-8 -*-
# vim: filetype=ruby

class Scomber

  def sava
    one = ARGV[0]
    two = ARGV[1]
    three = /#{ARGV[2]}/o
    four = ARGV[3]

    File.open(two, 'a:sjis', perm=0666) do |out_f|
      File.open(one) do |in_f|
        out_f.write in_f.read.gsub(three,four)
        print ' 置換処理を行い書き込み処理をしました、終了します... '
        in_f.close
        out_f.close
      end
    end
  end
end

me = ARGV[0]

case
  when me.nil?
    print 'sava is zinbei in Copyright Takayuki Kamiyama,I made in 2016.'
  when me
    Scomber.new.sava
  else
    print 'Not other arguments!'
end

__END__
