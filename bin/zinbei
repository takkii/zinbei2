def str
  open(ARGV[1]) do |f|
  while (name = f.readlines)
    name.sort!
    str = name.join(', ')
    p str.chomp!
    name.each do |n|
    puts n
    end
    exit!
 end
end
end

def line
count = 0

open(ARGV[1]) do |f|
  while f.gets
    f.each_line do
      count += 1
    end
  end
  print 'LineNumber is : '
  puts count

    print 'Did it read to the last of a page?：'
    puts f.eof?
  end
end

def upcase
open(ARGV[1]) do |f|
  while (name = f.readlines)
    name.encode('UTF-8').chomp!
    puts name.upcase!
 exit!
 end
end
end

def downcase
open(ARGV[1]) do |f|
  while (name = f.readlines)
    name.encode('UTF-8').chomp!
    puts name.downcase!
 exit!
 end
end
end


def num
open(ARGV[1]) do |f|
    while (name = f.gets)
      risk = name.encode('SJIS')
       printf('%4d : %s',f.lineno, risk)
   end
   puts ''
    exit!
end
end

module_function :start,:version,:datetime,:license,:command,:soft,:str,:line,:upcase,:downcase,:num
end


v = /\Aversion\z/
ve = /\A[-][v]\z/
d = /\A[-][d]\z/
da = /\Adatetime\z/
h = /\A[-][l]\z/
he = /\Alicense\z/
s = /\Astart\z/
so = /\A[-][s]\z/
co = /\A[-][h]\z/
com = /\Ahelp\z/
m = /\A[-][m]\z/
n = /\A[-][n]\z/
u = /\A[-][u]\z/
o = /\A[-][o]\z/
z = /\A[-][z]\z/

one = ARGV[0]

case
when one.nil?
Zinbei.soft
when one.match(v)
a=rand(15)
print '～'
i = 0
i < a
0.step(a) do |_|
  print '～'

end
puts '＜コ：彡'
puts
Zinbei.version
when one.match(ve)
Zinbei.version
when one.match(d)
Zinbei.datetime
when one.match(da)
require 'zinbei/ika'
Zinbei.datetime
when one.match(he)
Zinbei.license
when one.match(h)
Zinbei.license
when one.match(s)
Zinbei.start
when one.match(so)
Zinbei.start
when one.match(co)
Zinbei.command
when one.match(com)
Zinbei.command
when one.match(m)
Zinbei.str
when one.match(n)
Zinbei.line
when one.match(o)
Zinbei.downcase
when one.match(u)
Zinbei.upcase
when one.match(z)
Zinbei.num
else
puts 'Please choose an option.'
end

